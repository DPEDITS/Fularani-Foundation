{
  "rewrites": [
    { "source": "/((?!api|assets|sw\\.js|offline\\.html|logo\\.png|.*\\..*).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ]
}